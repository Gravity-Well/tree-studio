{
  "routes": [
    {
      "route": "/app",
      "rewrite": "/app.html"
    },
    {
      "route": "/terms",
      "rewrite": "/terms.html"
    },
    {
      "route": "/privacy",
      "rewrite": "/privacy.html"
    },
    {
      "route": "/api/share/*"
    },
    {
      "route": "/api/stripeWebhook",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/stripeConfig",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "rewrite": "/.auth/login/github"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    }
  ],
  "responseOverrides": {}
}
