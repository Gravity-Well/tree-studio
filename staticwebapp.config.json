{
  "routes": [
    {
      "route": "/embed-test",
      "rewrite": "/embed-test.html",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/help",
      "rewrite": "/help.html"
    },
    {
      "route": "/embed",
      "rewrite": "/embed.html"
    },
    {
      "route": "/app",
      "rewrite": "/app.html"
    },
    {
      "route": "/terms",
      "rewrite": "/terms.html"
    },
    {
      "route": "/privacy",
      "rewrite": "/privacy.html"
    },
    {
      "route": "/api/share/*"
    },
    {
      "route": "/api/contact",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/stripeWebhook",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/stripeConfig",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/aiGenerate",
      "allowedRoles": ["anonymous"]
    },
    {
      "route": "/api/deleteAccount",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/api/*",
      "allowedRoles": ["authenticated"]
    },
    {
      "route": "/login",
      "rewrite": "/login.html"
    },
    {
      "route": "/login/github",
      "rewrite": "/.auth/login/github"
    },
    {
      "route": "/login/microsoft",
      "rewrite": "/.auth/login/aad"
    },
    {
      "route": "/logout",
      "redirect": "/.auth/logout"
    }
  ],
  "responseOverrides": {
    "404": {
      "rewrite": "/404.html",
      "statusCode": 404
    }
  }
}
